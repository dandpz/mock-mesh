{
  "openapi": "3.0.3",
  "info": { "title": "Petstore", "version": "1.0.0" },
  "paths": {
    "/pets": {
      "get": {
        "operationId": "listPets",
        "responses": {
          "200": {
            "description": "a list of pets",
            "content": {
              "application/json": {
                "example": [
                  { "id": 1, "name": "rex" },
                  { "id": 2, "name": "bella" }
                ]
              }
            }
          }
        }
      }
    }
  }
}
